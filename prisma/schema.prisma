generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  sessions  Session[]
}

model Session {
  id        String   @id @default(cuid())
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model Page {
  id        String   @id @default(cuid())
  slug      String   @unique
  parentId  String?
  parent    Page?    @relation("PageTree", fields: [parentId], references: [id])
  children  Page[]   @relation("PageTree")
  title     String
  order     Int      @default(0)
  isVisible Boolean  @default(true)
  isHome    Boolean  @default(false)
  sections  Section[]
  seo       SeoSettings?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([parentId])
}

model Section {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  slug      String
  order     Int
  isVisible Boolean  @default(true)
  titlePl   String?
  titleEn   String?
  contentPl Json
  contentEn Json
  bgImage   String?
  bgColor   String?
  tags      String    @default("[]")
  galleryImages GalleryImage[]
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([pageId, slug])
}

model Client {
  id              String        @id @default(cuid())
  email           String        @unique
  name            String
  phone           String?
  locale          String        @default("pl")
  rating          Int?
  tags            String        @default("[]")
  adminNote       String?
  discount        Float         @default(0)
  isBlacklisted   Boolean       @default(false)
  blacklistReason String?
  reservations    Reservation[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Reservation {
  id            String            @id @default(cuid())
  guestName     String
  guestEmail    String
  guestPhone    String?
  checkIn       DateTime
  checkOut      DateTime
  guests        Int
  nights        Int
  totalPrice    Float
  comment       String?
  status        ReservationStatus @default(PENDING)
  adminNote     String?
  isPaid        Boolean           @default(false)
  depositAmount Float?
  depositPaidAt DateTime?
  clientId      String?
  client        Client?           @relation(fields: [clientId], references: [id])
  statusHistory StatusHistory[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([checkIn, checkOut])
  @@index([status])
  @@index([clientId])
}

model StatusHistory {
  id            String            @id @default(cuid())
  reservationId String
  reservation   Reservation       @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  oldStatus     ReservationStatus
  newStatus     ReservationStatus
  changedBy     String?
  createdAt     DateTime          @default(now())

  @@index([reservationId])
}

enum ReservationStatus {
  PENDING
  DEPOSIT_PAID
  PAID
  CANCELLED
  COMPLETED
}

model BlockedDate {
  id        String   @id @default(cuid())
  date      DateTime
  reason    String?
  type      String   @default("BLOCKED") // BLOCKED | SERVICE
  createdAt DateTime @default(now())

  @@unique([date])
  @@index([date])
}

model ICalFeed {
  id        String   @id @default(cuid())
  name      String
  url       String
  lastSync  DateTime?
  lastError String?
  createdAt DateTime @default(now())
}

model GalleryImage {
  id          String   @id @default(cuid())
  sectionId   String?
  section     Section? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  originalUrl String
  webpUrl     String
  thumbUrl    String?
  mobileUrl   String?
  altPl       String?
  altEn       String?
  captionPl   String?
  captionEn   String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([sectionId])
}

model SeoSettings {
  id             String  @id @default(cuid())
  pageId         String  @unique
  page           Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  titlePl        String?
  titleEn        String?
  descriptionPl  String?
  descriptionEn  String?
  ogImageUrl     String?
  customHeadTags String?
}

model SiteSettings {
  id    String @id @default(cuid())
  key   String @unique
  value Json
}

model PricingRule {
  id            String   @id @default(cuid())
  label         String
  dateFrom      DateTime
  dateTo        DateTime
  pricePerNight Float
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([dateFrom, dateTo])
}
